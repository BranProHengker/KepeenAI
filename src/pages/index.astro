---
import '@/styles/global.css';
import Uploader from '../components/Uploader';
import { Flame, Scale, Rocket, Skull } from 'lucide-react';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>kepeenAI</title>
    <!-- Importing Inter and Fragment Mono from Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fragment+Mono&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
  </head>
  <body class="bg-beige text-charcoal min-h-screen flex flex-col font-sans">
    
    <!-- Navbar -->
    <header class="border-b-2 border-deep-black bg-white">
      <div class="max-w-[1200px] mx-auto px-6 py-4 flex justify-between items-center">
        <div class="flex items-center gap-2">
          <img src="/favicon.svg" alt="kepeenAI Logo" class="w-8 h-8" />
          <div class="text-[24px] font-bold text-deep-black tracking-tight">kepeenAI</div>
        </div>
        <a href="/chat" class="hidden md:inline-block font-mono text-[12px] bg-deep-black text-white px-4 py-2 uppercase hover:bg-charcoal transition-colors">Launch App</a>
      </div>
    </header>

    <!-- Marquee Banner -->
    <div class="border-b-2 border-deep-black bg-deep-black text-beige overflow-hidden py-2 flex">
      <div class="font-mono text-[12px] uppercase whitespace-nowrap animate-[marquee_20s_linear_infinite]">
        ROAST YOUR SETUP • ARCHITECTURAL UPGRADE • BRUTAL FEEDBACK • GLOW-UP SCORE • AI-POWERED • ROAST YOUR SETUP • ARCHITECTURAL UPGRADE • BRUTAL FEEDBACK • GLOW-UP SCORE • AI-POWERED • 
      </div>
    </div>

    <!-- Hero Section -->
    <main class="flex-grow flex flex-col">
      <section class="max-w-[1200px] mx-auto px-6 py-16 md:py-32 w-full flex flex-col md:flex-row gap-12 items-center">
        <div class="flex-1 flex flex-col items-start">
          <div class="inline-block border-2 border-deep-black px-3 py-1 font-mono text-[12px] uppercase mb-6 bg-white shadow-[4px_4px_0px_rgba(11,16,18,1)]">
            AI Setup Architect
          </div>
          <h1 class="text-[64px] md:text-[88px] leading-[0.9] font-bold text-deep-black mb-6 tracking-tight uppercase">
            Roast Your <br/><span class="text-white text-shadow-solid">Setup.</span>
          </h1>
          <p class="font-sans text-[18px] md:text-[20px] leading-[1.5] max-w-lg mb-10 text-charcoal border-l-4 border-deep-black pl-4">
            Upload your desk setup or workspace. Our AI will analyze the structural integrity, roast your aesthetic choices without mercy, and provide a premium upgrade plan.
          </p>
          
          <a href="/chat" class="group relative inline-flex items-center justify-center font-mono text-[16px] font-bold uppercase tracking-wider text-white bg-deep-black px-8 py-5 border-2 border-deep-black hover:bg-white hover:text-deep-black transition-all shadow-[8px_8px_0px_rgba(11,16,18,1)] hover:shadow-none hover:translate-x-2 hover:translate-y-2">
            Start Roasting <Rocket className="w-5 h-5 ml-2" />
          </a>
        </div>

        <!-- Terminal Mockup Graphic -->
        <div class="flex-1 w-full relative h-[400px] border-4 border-deep-black bg-white shadow-[16px_16px_0px_rgba(11,16,18,1)] p-6 flex flex-col">
          <div class="font-mono text-[14px] text-taupe uppercase tracking-widest mb-6 border-b-2 border-deep-black pb-4 flex justify-between items-center">
            <span>&gt; KEPEEN_AI_TERMINAL</span>
            <span class="text-deep-black bg-beige px-2 border border-deep-black">v1.0</span>
          </div>
          <div class="flex-grow font-mono text-[14px] md:text-[16px] leading-relaxed text-deep-black flex flex-col justify-center">
            <p class="text-taupe mb-2">Analyzing structural integrity...</p>
            <p class="mb-4 text-red-500 font-bold">>> ERROR: AESTHETIC_NOT_FOUND</p>
            <p class="mb-2 text-charcoal">> Cable management: <span class="bg-deep-black text-white px-1">FAILED</span></p>
            <p class="mb-2 text-charcoal">> RGB sync: <span class="bg-deep-black text-white px-1">MISMATCHED</span></p>
            <p class="mb-6 text-charcoal">> Ergonomics: <span class="bg-deep-black text-white px-1">SPINAL_DAMAGE_IMMINENT</span></p>
            <p class="animate-pulse bg-deep-black text-white self-start px-2 py-1">RECOMMENDATION: BRUTAL ROAST REQUIRED_</p>
          </div>
        </div>
      </section>

      <!-- Features Section -->
      <section class="border-t-2 border-deep-black bg-white flex-grow">
        <div class="max-w-[1200px] mx-auto px-6 py-20">
          <h2 class="font-mono text-[24px] font-bold text-deep-black mb-12 uppercase">Select Your Mode</h2>
          <div class="grid md:grid-cols-2 gap-8">
            
            <div class="border-2 border-deep-black p-8 bg-beige hover:bg-white transition-colors">
              <Flame className="w-10 h-10 mb-4" />
              <h3 class="font-sans text-[24px] font-bold text-deep-black mb-4">Brutal Roast</h3>
              <p class="font-sans text-[16px] text-charcoal mb-6">
                Upload up to 2 images of your current setup. Get a brutally honest score out of 100 and actionable architectural upgrades. Not for the faint of heart.
              </p>
              <a href="/chat" class="font-mono text-[14px] text-deep-black uppercase font-bold underline hover:no-underline">&gt; Try Roast Mode</a>
            </div>

            <div class="border-2 border-deep-black p-8 bg-beige hover:bg-white transition-colors">
              <Scale className="w-10 h-10 mb-4" />
              <h3 class="font-sans text-[24px] font-bold text-deep-black mb-4">Compare Glow-Up</h3>
              <p class="font-sans text-[16px] text-charcoal mb-6">
                Already upgraded? Upload your "Before" and "After" photos to see if your changes actually improved the vibe, or if you just wasted money.
              </p>
              <a href="/chat" class="font-mono text-[14px] text-deep-black uppercase font-bold underline hover:no-underline">&gt; Try Compare Mode</a>
            </div>

          </div>
        </div>
      </section>
    </main>

    <!-- Footer -->
    <footer class="border-t-2 border-deep-black bg-deep-black text-white">
      <div class="max-w-[1200px] mx-auto px-6 py-8 flex flex-col md:flex-row justify-between items-center gap-4">
        <div class="font-mono text-[12px] uppercase opacity-70">© 2026 kepeenAI. All rights reserved.</div>
        <div class="font-mono text-[12px] uppercase opacity-70 flex items-center gap-1">Built with <Skull className="w-4 h-4" /> Brutal Honesty</div>
      </div>
    </footer>

    <style>
      .text-shadow-solid {
        text-shadow: -2px -2px 0 #0B1012, 2px -2px 0 #0B1012, -2px 2px 0 #0B1012, 2px 2px 0 #0B1012;
      }
      @keyframes marquee {
        0% { transform: translateX(0); }
        100% { transform: translateX(-50%); }
      }
    </style>
  </body>
</html>
